generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  fullName        String    @map("full_name")
  phone           String?
  role            String    @default("customer")
  isActive        Boolean   @default(false) @map("is_active")
  isApproved      Boolean   @default(false) @map("is_approved")
  emailVerified   Boolean   @default(false) @map("email_verified")
  verifyToken     String?   @map("verify_token")
  resetToken      String?   @map("reset_token")
  resetTokenExp   DateTime? @map("reset_token_exp")
  province        String?
  district        String?
  village         String?
  landmark        String?
  companyName     String?   @map("company_name")
  businessLicense String?   @map("business_license")
  taxId           String?   @map("tax_id")
  contactPerson   String?   @map("contact_person")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  products          Product[]
  cartItems         CartItem[]
  orders            Order[]
  sponsorshipReqs   SponsorshipRequest[]
  deliveryOrders    Order[]              @relation("DeliveryPerson")
  deliveryLocations DeliveryLocation[]

  @@map("users")
}

model Category {
  id       Int        @id @default(autoincrement())
  slug     String     @unique
  nameEn   String     @map("name_en")
  namePs   String     @map("name_ps")
  nameDr   String     @map("name_dr")
  parentId Int?       @map("parent_id")
   parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id              Int      @id @default(autoincrement())
  nameEn          String   @map("name_en")
  namePs          String   @map("name_ps")
  nameDr          String   @map("name_dr")
  descEn          String?  @db.Text @map("desc_en")
  descPs          String?  @db.Text @map("desc_ps")
  descDr          String?  @db.Text @map("desc_dr")
  wholesaleCost   Float    @map("wholesale_cost")
  suggestedPrice  Float?   @map("suggested_price")
  retailPrice     Float?   @map("retail_price")
  stock           Int      @default(0)
  status          String   @default("pending")
  adminNotes      String?  @db.Text @map("admin_notes")
  isSponsored     Boolean  @default(false) @map("is_sponsored")
  attributes      String?  @db.Text
  isDeleted       Boolean  @default(false) @map("is_deleted")
  supplierId      Int      @map("supplier_id")
  categoryId      Int?     @map("category_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  supplier          User                 @relation(fields: [supplierId], references: [id])
  category          Category?            @relation(fields: [categoryId], references: [id])
  images            ProductImage[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  sponsorshipReqs   SponsorshipRequest[]

  @@fulltext([nameEn, namePs, nameDr])
  @@fulltext([nameEn, namePs, nameDr, descEn, descPs, descDr])
  @@index([status])
  @@index([supplierId])
  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  productId Int     @map("product_id")
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

model Order {
  id               Int       @id @default(autoincrement())
  orderNumber      String    @unique @map("order_number")
  userId           Int       @map("user_id")
  status           String    @default("pending")
  totalAmount      Float     @map("total_amount")
  paymentStatus    String    @default("unpaid") @map("payment_status")
  province         String?
  district         String?
  village          String?
  landmark         String?
  phone            String?
  deliveryPersonId Int?      @map("delivery_person_id")
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user           User        @relation(fields: [userId], references: [id])
  deliveryPerson User?       @relation("DeliveryPerson", fields: [deliveryPersonId], references: [id])
  items          OrderItem[]

  @@index([status])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id            Int   @id @default(autoincrement())
  orderId       Int   @map("order_id")
  productId     Int   @map("product_id")
  quantity      Int
  retailPrice   Float @map("retail_price")
  wholesaleCost Float @map("wholesale_cost")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model SponsorshipPackage {
  id          Int      @id @default(autoincrement())
  name        String
  durationDays Int     @map("duration_days")
  price       Float
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  requests SponsorshipRequest[]

  @@map("sponsorship_packages")
}

model SponsorshipRequest {
  id         Int       @id @default(autoincrement())
  supplierId Int       @map("supplier_id")
  productId  Int       @map("product_id")
  packageId  Int       @map("package_id")
  status     String    @default("pending")
  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  supplier User               @relation(fields: [supplierId], references: [id])
  product  Product            @relation(fields: [productId], references: [id])
  package  SponsorshipPackage @relation(fields: [packageId], references: [id])

  @@map("sponsorship_requests")
}

model DeliveryLocation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  latitude  Float
  longitude Float
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("delivery_locations")
}

model SiteContent {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.LongText
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_content")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model TransactionLog {
  id          Int      @id @default(autoincrement())
  action      String
  entity      String
  entityId    Int?     @map("entity_id")
  userId      Int?     @map("user_id")
  userName    String?  @map("user_name")
  details     String?  @db.Text
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("transaction_logs")
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  titleEn     String   @map("title_en")
  titlePs     String?  @map("title_ps")
  titleDr     String?  @map("title_dr")
  slug        String   @unique
  excerptEn   String?  @map("excerpt_en") @db.Text
  excerptPs   String?  @map("excerpt_ps") @db.Text
  excerptDr   String?  @map("excerpt_dr") @db.Text
  contentEn   String?  @map("content_en") @db.LongText
  contentPs   String?  @map("content_ps") @db.LongText
  contentDr   String?  @map("content_dr") @db.LongText
  image       String?
  authorId    Int?     @map("author_id")
  authorName  String?  @map("author_name")
  category    String?
  tags        String?
  isPublished Boolean  @default(false) @map("is_published")
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isPublished])
  @@index([createdAt])
  @@map("blog_posts")
}

model Subscriber {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  isActive   Boolean  @default(true) @map("is_active")
  couponCode String?  @map("coupon_code")
  couponUsed Boolean  @default(false) @map("coupon_used")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("subscribers")
}

model Coupon {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  discount  Float
  isPercent Boolean   @default(true) @map("is_percent")
  minOrder  Float     @default(0) @map("min_order")
  maxUses   Int       @default(1) @map("max_uses")
  usedCount Int       @default(0) @map("used_count")
  isActive  Boolean   @default(true) @map("is_active")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("coupons")
}
